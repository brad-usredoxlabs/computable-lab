{
  "name": "computable",
  "private": true,
  "workspaces": ["server", "app"],
  "scripts": {
    "dev": "./start-app.sh",
    "dev:server": "npm run dev -w server",
    "dev:app": "npm run dev -w app",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w app",
    "test": "npm run test -w server && npm run test -w app",
    "test:app": "npm run test -w app",
    "test:unit": "pnpm --filter app exec vitest run",
    "test:spec-029": "pnpm --filter app exec vitest run src/extraction/ExtractionReviewPage.test.tsx",
    "vitest": "npx vitest",
"vitest:server": "pnpm --filter server exec vitest",
    "download:ontology": "tsx scripts/download-ontology.ts"
  }
}
